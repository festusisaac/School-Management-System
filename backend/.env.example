# ===== SERVER CONFIGURATION =====
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ===== DATABASE CONFIGURATION =====
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=sms_user
DATABASE_PASSWORD=your_secure_password
DATABASE_NAME=sms_db
DATABASE_SYNC=false
DATABASE_LOGGING=true

# ===== REDIS CONFIGURATION =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== JWT CONFIGURATION =====
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
REFRESH_TOKEN_EXPIRE=7d

# ===== PAYMENT GATEWAY (PAYSTACK) =====
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# ===== PAYSTACK - FLUTTERWAVE ALTERNATIVE =====
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key

# ===== SMS PROVIDER (TERMII) =====
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=SMS-SCHOOL
TERMII_BASE_URL=https://api.termii.com
TERMII_CHANNEL=generic

# ===== EMAIL CONFIGURATION (AMAZON SES SMTP) =====
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your_ses_smtp_username
SMTP_PASSWORD=your_ses_smtp_password
SMTP_SECURE=false
SMTP_FROM=noreply@yourverifieddomain.com

# ===== EMAIL CONFIGURATION (RESEND) =====
# To switch to Resend, set MAIL_PROVIDER=resend
MAIL_PROVIDER=smtp
RESEND_API_KEY=re_123456789
RESEND_FROM=onboarding@resend.dev

# ===== FILE STORAGE (AWS S3) =====
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=sms-bucket
AWS_REGION=us-east-1

# ===== CLOUD STORAGE ALTERNATIVE (CLOUDINARY) =====
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ===== CORS =====
CORS_ORIGIN=http://localhost:3001,https://yourdomain.com

# ===== TIMEZONE =====
TZ=Africa/Lagos

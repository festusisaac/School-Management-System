# ===== SERVER CONFIGURATION =====
NODE_ENV=test
PORT=3000
API_VERSION=v1

# ===== DATABASE CONFIGURATION =====
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=sms_user
DATABASE_PASSWORD=your_secure_password
DATABASE_NAME=sms_test_db
DATABASE_SYNC=true
DATABASE_LOGGING=false

# ===== REDIS CONFIGURATION =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== JWT CONFIGURATION =====
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRE=24h
REFRESH_TOKEN_SECRET=change_this_refresh_secret
REFRESH_TOKEN_EXPIRE=7d

# ===== PAYMENT GATEWAY (PAYSTACK) =====
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# ===== PAYSTACK - FLUTTERWAVE ALTERNATIVE =====
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key

# ===== SMS PROVIDER (TERMII) =====
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=SMS-SCHOOL

# ===== EMAIL CONFIGURATION =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@schoolmanagementsystem.com

# ===== FILE STORAGE (AWS S3) =====
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=sms-bucket
AWS_REGION=us-east-1

# ===== CLOUD STORAGE ALTERNATIVE (CLOUDINARY) =====
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_FILE=logs/test.log

# ===== CORS =====
CORS_ORIGIN=http://localhost:3001,https://yourdomain.com

# ===== TIMEZONE =====
TZ=Africa/Lagos

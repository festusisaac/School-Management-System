# ===== SERVER CONFIGURATION =====
NODE_ENV=production
PORT=3000
API_VERSION=v1
FRONTEND_URL=https://yourdomain.com

# ===== DATABASE CONFIGURATION =====
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=sms_prod_user
DATABASE_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_123!@#
DATABASE_NAME=sms_production
DATABASE_SYNC=false
DATABASE_LOGGING=false

# ===== REDIS CONFIGURATION =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD!@#
REDIS_DB=0

# ===== JWT CONFIGURATION =====
JWT_SECRET=CHANGE_THIS_SUPER_SECRET_JWT_KEY_USE_RANDOM_STRING!@#$%^&*
JWT_EXPIRE=24h
REFRESH_TOKEN_SECRET=CHANGE_THIS_REFRESH_SECRET_KEY!@#$%^&*
REFRESH_TOKEN_EXPIRE=7d

# ===== PAYMENT GATEWAY (PAYSTACK) =====
PAYSTACK_SECRET_KEY=sk_live_XXXXXXXXXXXXX
PAYSTACK_PUBLIC_KEY=pk_live_XXXXXXXXXXXXX

# ===== SMS PROVIDER (TERMII) =====
TERMII_API_KEY=your_termii_live_api_key
TERMII_SENDER_ID=SMS-SCHOOL

# ===== EMAIL CONFIGURATION =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@schoolmanagementsystem.com

# ===== FILE STORAGE (AWS S3) =====
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=sms-prod-bucket
AWS_REGION=us-east-1

# ===== CLOUDINARY (ALTERNATIVE) =====
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FILE=/var/log/app.log

# ===== CORS =====
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ===== TIMEZONE =====
TZ=Africa/Lagos

# ===== SSL/TLS CERTIFICATES =====
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem

# ===== BACKUP CONFIGURATION =====
BACKUP_S3_BUCKET=sms-backups-prod
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * * # 2 AM daily

# ===== MONITORING & ALERTING =====
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
DATADOG_API_KEY=your_datadog_api_key
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ===== API CONFIGURATION =====
API_RATE_LIMIT=100
API_RATE_WINDOW=15m

# ===== SECURITY =====
BCRYPT_ROUNDS=12
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET_KEY!@#$%^&*
